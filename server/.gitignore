#  환경 변수
.env
.env.*

#  파이썬 캐시
__pycache__/
*.py[cod]
*.pyo

#  패키지 빌드
build/
dist/
*.egg-info/

#  테스트 & 분석 도구
.pytest_cache/
.coverage
.mypy_cache/
.ipynb_checkpoints/

