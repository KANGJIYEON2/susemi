#  법령 API 캐시 (스냅샷은 .gitkeep 만 추적)
app/data/legal_cache/**
!app/data/legal_cache/
!app/data/legal_cache/.gitkeep

#  RAG 인덱스 (임베딩 — 파생 데이터)
