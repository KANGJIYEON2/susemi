# susemi 환경변수 예시
# 실제 값은 .env 에 기록하고 git 에 올리지 말 것

# OpenAI API (PDF 파싱 + Why 분석 LLM 호출용)
OPENAI_API_KEY=sk-...

# 국가법령정보센터 OPEN API (open.law.go.kr) — OC 코드
# 발급: open.law.go.kr 회원가입 → OC 신청. 이메일 ID(예: your_id) 가 곧 OC.
OPEN_LAW_API_KEY=api 키

# Admin 토큰 — /admin/* 와 /rag/* 라우트 가드용. 임의 긴 문자열 권장.
# 미설정 시 admin 기능 503 으로 비활성. 클라이언트는 X-Admin-Token 헤더로 전송.
ADMIN_TOKEN=change_me_to_a_long_random_string

# CORS 허용 origin (쉼표 구분). 미설정시 dev 디폴트 (localhost:3000).
# 도메인 붙이면 추가: "https://susemi.kr,http://1.2.3.4"
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Docker compose / Caddy 사이트 주소
# 도메인 없을 때: ":80"  (HTTP, EC2 IP 로 접속)
# 도메인 붙일 때: "susemi.kr"  (자동 Let's Encrypt SSL)
SITE_ADDRESS=:80
