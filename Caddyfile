# Caddyfile — reverse proxy + 자동 SSL
#
# 사이트 주소는 환경변수로 주입.
#   - 도메인 없을 때: SITE_ADDRESS=:80      (HTTP, EC2 IP 로 접속)
#   - 도메인 있을 때: SITE_ADDRESS=susemi.kr (자동 Let's Encrypt SSL)
#
# /api/* → FastAPI (server:8000)
# 그 외   → Next.js (client:3000)

{$SITE_ADDRESS} {
    encode gzip zstd

    # 백엔드 라우팅 — handle (not handle_path) 로 prefix 유지
    handle /api/* {
        reverse_proxy server:8000
    }

    # 프론트엔드 라우팅 (Next.js)
    handle {
        reverse_proxy client:3000
    }

    # 보안 헤더
    header {
        # XSS / MIME sniffing
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
        # HSTS — SITE_ADDRESS 가 도메인일 때만 의미 있음
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        # admin/* robots noindex 는 프론트 metadata 에서 처리
    }

    log {
        output stdout
        format console
        level INFO
    }
}
